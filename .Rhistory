#| label: setup
#| include: false
#| message: false
#| warning: false
if (!require("data.table")) install.packages("data.table")
if (!require("dplyr")) install.packages("dplyr")
if (!require("skimr")) install.packages("skimr")
if (!require("ggplot2")) install.packages("ggplot2")
if (!require("GGally")) install.packages("GGally")
library(data.table)
library(dplyr)
library(skimr)
library(ggplot2)
library(GGally)
# # Random sample your group's data set from the original LCdata data set
# LCdata <- fread("LCdata.csv")
# set.seed(1)
# myLCdata <- LCdata %>% sample(5) %>% slice_sample(prop = .5)
# fwrite(myLCdata, file = "myLCdata.csv")
myLCdata <- fread("myLCdata.csv")
#| label: structure-overview
glimpse(myLCdata)
str(myLCdata)
#| label: summary-statistics
summary(myLCdata)
# install skimr if necessary
if (!require("skimr")) install.packages("skimr")
library(skimr)
skim(myLCdata)
#| label: plot-var1
# Insert ggplot code here
ggplot(myLCdata, aes(y = annual_inc)) +
geom_boxplot()
#| label: plot-var1
# For distribution
ggplot(myLCdata, aes(y = annual_inc)) +
geom_boxplot() +
scale_y_log10() +
labs(title = "Boxplot of Annual Income (Log Scale)",
y = "Annual Income (log scale)") +
theme_minimal()
#For Outliers
#| label: plot-var1
# For distribution
ggplot(myLCdata, aes(y = annual_inc)) +
geom_boxplot(outlier.colour = "red", outlier.alpha = 0.4) +
labs(title = "Boxplot of Annual Income",
y = "Annual Income") +
theme_minimal()
#For Outliers
#| label: plot-var1
# For distribution
ggplot(myLCdata, aes(y = annual_inc)) +
geom_boxplot(outlier.colour = "red") +
labs(title = "Boxplot of Annual Income",
y = "Annual Income") +
theme_minimal()
#For Outliers
#| label: plot-var1
# For distribution = outlier detection
# Calculate quartiles and IQR
Q1 <- quantile(myLCdata$annual_inc, 0.25, na.rm = TRUE)
Q3 <- quantile(myLCdata$annual_inc, 0.75, na.rm = TRUE)
IQR_value <- IQR(myLCdata$annual_inc, na.rm = TRUE)
# Define bounds
lower_bound <- Q1 - 1.5 * IQR_value
upper_bound <- Q3 + 1.5 * IQR_value
# Extract outliers
outliers <- myLCdata$annual_inc[
myLCdata$annual_inc < lower_bound |
myLCdata$annual_inc > upper_bound
]
length(outliers)  # number of outliers
summary(outliers)
#For Outliers
#| label: plot-var1
# For distribution = outlier detection
library(dplyr)
bounds <- myLCdata %>%
summarise(
Q1 = quantile(annual_inc, 0.25, na.rm = TRUE),
Q3 = quantile(annual_inc, 0.75, na.rm = TRUE),
IQR = IQR(annual_inc, na.rm = TRUE)
)
lower <- bounds$Q1 - 1.5 * bounds$IQR
upper <- bounds$Q3 + 1.5 * bounds$IQR
outliers <- myLCdata %>%
filter(annual_inc < lower | annual_inc > upper)
#For Outliers
